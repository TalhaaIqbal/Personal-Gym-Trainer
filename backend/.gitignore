# --- Secrets / env files ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- ML artifacts / models ---
*.pkl
*.joblib
*.h5
*.onnx
app/ml/artifacts/*
!app/ml/artifacts/.gitkeep

# --- Datasets (often large / shouldn't be committed) ---
# Uncomment if your dataset is large or sensitive:
# app/ml/dataset/*.csv

# --- Jupyter ---
.ipynb_checkpoints/

# --- Databases ---
*.db
*.sqlite
*.sqlite3

# --- Testing / coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Type checking / linting caches ---
.mypy_cache/
.ruff_cache/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/